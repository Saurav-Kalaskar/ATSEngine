# LLM Provider: openrouter (default) or puter
LLM_PROVIDER=openrouter

# Shared model selector
LLM_MODEL=qwen/qwen3.6-plus:free

# OpenRouter configuration (used when LLM_PROVIDER=openrouter)
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_API_KEY=sk-or-v1-your-openrouter-key-here

# Puter configuration (used when LLM_PROVIDER=puter)
# Puter auth is usually passed from frontend via X-PUTER-AUTH-TOKEN.
# PUTER_AUTH_TOKEN is optional fallback for local testing only.
PUTER_API_ORIGIN=https://api.puter.com
PUTER_AUTH_TOKEN=
PUTER_REQUEST_ORIGIN=https://puter.work
PUTER_REQUEST_REFERER=https://puter.work/
